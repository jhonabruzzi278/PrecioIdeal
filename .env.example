# Copy this file to .env and fill in real values. .env is gitignored.

# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
# In Railway: ALLOWED_HOSTS=<your-service>.up.railway.app (or your custom domain)
# CSRF_TRUSTED_ORIGINS=https://<your-service>.up.railway.app

# Database — Django reads this single URL.
# Postgres (default, matches the docker-compose service):
DATABASE_URL=postgres://precioideal:precioideal@localhost:5432/precioideal
# In Railway: add a Postgres plugin, it injects DATABASE_URL automatically —
# don't set it manually there.
# To dump legacy data from the old SQLite file, override temporarily:
#   DATABASE_URL=sqlite:///db.sqlite3 python manage.py dumpdata ...

# POSTGRES_* configure the postgres container itself (used by docker-compose).
POSTGRES_DB=precioideal
POSTGRES_USER=precioideal
POSTGRES_PASSWORD=precioideal

# Host ports for the docker-compose services. Change these if the default ports
# are already taken on your machine (e.g. another project using 5432).
POSTGRES_HOST_PORT=5432
REDIS_HOST_PORT=6379

# Redis cache (matches docker-compose.yml default for local dev)
REDIS_URL=redis://localhost:6379/0
# In Railway: add a Redis plugin, it injects REDIS_URL automatically —
# don't set it manually there.

# Production-only (ignored while DEBUG=True)
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=2592000

# Flow (billing) — placeholders, filled in during the billing integration phase
FLOW_API_KEY=
FLOW_SECRET_KEY=
FLOW_API_BASE_URL=https://sandbox.flow.cl/api
